// File name: projects/01/Mux.hdl

/** 
 * Multiplexor:
 * out = a if sel == 0
 *       b otherwise
 */

CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
    Not(in = sel, out = ns);
    And(a = ns, b = a, out = nsa);
    And(a = sel, b = b, out = sb);
    Or(a = nsa, b= sb, out = out);
}